# ── Production Environment Variables ──────────────────────────────────────
# Copy to .env.production (gitignored) and fill in real values.
# For VPS deployment: set API_BASE in your host's env settings.
# For Vercel: add API_BASE as a server-only environment variable in project settings.

# Real backend API URL — server-side only, never exposed to the browser
API_BASE=http://your-api-host:4000
